/// ERyder.java
public class ERyder {
    private String bikeID;
    private int batteryLevel;
    private boolean isAvailable;
    private double kmDriven;
    
    // Default constructor
    public ERyder() {
        this.bikeID = "Unknown";
        this.batteryLevel = 0;
        this.isAvailable = false;
        this.kmDriven = 0.0;
    }
    
    // Constructor with all parameters
    public ERyder(String bikeID, int batteryLevel, boolean isAvailable, double kmDriven) {
        this.bikeID = bikeID;
        setBatteryLevel(batteryLevel); // Using setter to validate
        this.isAvailable = isAvailable;
        this.kmDriven = kmDriven;
    }
    
    // ride method
    public void ride() {
        if (batteryLevel > 0 && isAvailable) {
            System.out.println("Bike " + bikeID + " is available for riding.");
        } else {
            System.out.println("Bike " + bikeID + " is not available.");
            if (batteryLevel <= 0) {
                System.out.println("Reason: Battery level is low (" + batteryLevel + "%)");
            }
            if (!isAvailable) {
                System.out.println("Reason: Bike is currently not available");
            }
        }
    }
    
    // Method to print bike details
    public void printBikeDetails() {
        System.out.println("===== Bike Details =====");
        System.out.println("Bike ID: " + bikeID);
        System.out.println("Battery Level: " + batteryLevel + "%");
        System.out.println("Availability: " + (isAvailable ? "Available" : "Not Available"));
        System.out.println("Distance Travelled: " + kmDriven + " km");
        System.out.println("========================");
    }
    
    // Getters and Setters
    public String getBikeID() {
        return bikeID;
    }
    
    public void setBikeID(String bikeID) {
        this.bikeID = bikeID;
    }
    
    public int getBatteryLevel() {
        return batteryLevel;
    }
    
    // Setter with validation (0-100 only)
    public void setBatteryLevel(int batteryLevel) {
        if (batteryLevel >= 0 && batteryLevel <= 100) {
            this.batteryLevel = batteryLevel;
        } else {
            System.out.println("Error: Battery level must be between 0 and 100. Setting to 0.");
            this.batteryLevel = 0;
        }
    }
    
    public boolean isAvailable() {
        return isAvailable;
    }
    
    public void setAvailable(boolean available) {
        isAvailable = available;
    }
    
    public double getKmDriven() {
        return kmDriven;
    }
    
    public void setKmDriven(double kmDriven) {
        this.kmDriven = kmDriven;
    }
}
/ Main.java
public class Main {
    public static void main(String[] args) {
        System.out.println("eRyder E-Bike Sharing Service\n");
        
        // Create object using default constructor
        System.out.println("Creating bike with default constructor:");
        ERyder bike1 = new ERyder();
        bike1.printBikeDetails();
        
        System.out.println("\n-----------------------------------\n");
        
        // Create object using parameterized constructor
        System.out.println("Creating bike with parameterized constructor:");
        ERyder bike2 = new ERyder("ER001", 85, true, 120.5);
        
        // Call ride method
        System.out.println("Calling ride() method:");
        bike2.ride();
        
        System.out.println();
        
        // Print bike details
        bike2.printBikeDetails();
        
        System.out.println("\n-----------------------------------\n");
        
        // Test with unavailable bike
        System.out.println("Testing with unavailable bike:");
        ERyder bike3 = new ERyder("ER002", 5, false, 350.0);
        bike3.ride();
        bike3.printBikeDetails();
        
        System.out.println("\n-----------------------------------\n");
        
        // Test battery level validation
        System.out.println("Testing battery level validation:");
        ERyder bike4 = new ERyder("ER003", 150, true, 75.2); // Invalid battery level
        bike4.printBikeDetails();
    }
}